---
layout: none
---
[
  {% comment %} ===== Articles ===== {% endcomment %}
  {% for post in site.posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | jsonify }},
      "content": {{ post.content | strip_html | normalize_whitespace | truncatewords: 60 | jsonify }},
      "type": "Article"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}

  {% comment %} ===== Emagazines (if collection exists) ===== {% endcomment %}
  {% if site.emagazines %}
  {% for mag in site.emagazines %}
    ,
    {
      "title": {{ mag.title | jsonify }},
      "url": {{ mag.url | jsonify }},
      "content": {{ mag.content | strip_html | normalize_whitespace | truncatewords: 60 | jsonify }},
      "type": "Emagazine"
    }
  {% endfor %}
  {% endif %}

  {% comment %} ===== Static pages (all .html files in root that have front matter) ===== {% endcomment %}
  {% for page in site.pages %}
    {% if page.title and page.url != "/assets/css/main.css" and page.url != "/search.json" %}
    ,
    {
      "title": {{ page.title | jsonify }},
      "url": {{ page.url | jsonify }},
      "content": {{ page.content | strip_html | normalize_whitespace | truncatewords: 60 | jsonify }},
      "type": "Page"
    }
    {% endif %}
  {% endfor %}

  {% comment %} ===== Data‑driven pages (community, policies, legal, etc.) ===== {% endcomment %}
  {% assign data_pages = "community-connections,content-removal,policies,legal,about,disclaimer,connect,newsletter,subscribers,events,local-stories,breaking-news,politics,independent-journalist" | split: "," %}
  {% for slug in data_pages %}
    {% assign data = site.data[slug] %}
    {% if data.heading or data.title %}
    ,
    {
      "title": {{ data.heading | default: data.title | jsonify }},
      "url": "/{{ slug }}/",
      "content": {{ data.intro | default: data.body | default: data.message | strip_html | normalize_whitespace | truncatewords: 60 | jsonify }},
      "type": "Page"
    }
    {% endif %}
  {% endfor %}
]
